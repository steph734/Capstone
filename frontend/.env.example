VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Daily.co Video — dashboard.daily.co -> Rooms -> Create room -> copy its URL.
# Keep the room's Privacy set to "Public" so no API key or backend token is
# needed at all — anyone with the URL can join directly from the browser.
VITE_DAILY_ROOM_URL=https://your-domain.daily.co/your-room-name

# Stripe publishable key — dashboard.stripe.com -> Developers -> API keys.
# Safe to expose client-side. The matching secret key goes in the repo-root
# .env as STRIPE_SECRET_KEY (see ../.env.example), never here.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
