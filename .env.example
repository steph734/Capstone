# Stripe secret key — dashboard.stripe.com -> Developers -> API keys -> Secret key.
# Server-side only. NEVER put this in frontend/.env or commit it — copy this file to
# ".env" (gitignored) for local dev, and add the same variable in your Vercel
# project's Environment Variables for production.
STRIPE_SECRET_KEY=sk_test_your_secret_key

# ElevenLabs TTS — elevenlabs.io -> Profile -> API keys. Powers Pao the panda's
# realistic voice (api/tts.js). Server-side only. Without this set, Pao
# automatically falls back to the browser's built-in speech synthesis.
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Optional overrides — see api/_lib/elevenLabsTts.js for defaults.
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
